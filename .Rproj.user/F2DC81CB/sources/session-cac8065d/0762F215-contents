# ── Mechanistic categories for predictor grouping ────────────────────────
# Top 2 predictors must come from different categories to ensure
# orthogonal information content.
mech_category <- setNames(
  c(rep("upwelling_proxy", 5),   # Min temp = upwelling proxy
    rep("thermal_stress", 5),     # Max temp = thermal stress
    rep("transport", 5),          # CUTI = physical transport
    rep("nutrient_flux", 5),      # BEUTI = biological productivity
    rep("freshwater", 5),         # Salinity = freshwater balance
    rep("river_flow", 5)),        # Discharge = Columbia River flow
  tv_all
)

# ── Predictor selection: top 2 from different mechanistic categories ─────
# Uses monthly timescale correlations. For each beach × recruit type,
# rank all predictor-lag combinations by |r|, then select top 1 overall
# and top 1 from a different mechanistic category.

cor_monthly <- cor_all %>% filter(timescale == "monthly")

select_top_predictors <- function(cor_data) {
  
  # Pivot to one row per beach × recruit_type × predictor × lag
  cor_long <- cor_data %>%
    select(beach, lag, temp_var, window, metric, r_pre, r_rec, p_pre, p_rec, n) %>%
    pivot_longer(c(r_pre, r_rec),
                 names_to = "recruit_type", values_to = "r") %>%
    mutate(
      p = ifelse(recruit_type == "r_pre", p_pre, p_rec),
      n_eff = ifelse(recruit_type == "r_pre",
                     n,  # n already computed for pre-recruits
                     n), # same n for recruits from same join
      recruit_type = recode(recruit_type,
                            r_pre = "Pre-recruits", r_rec = "Recruits"),
      abs_r    = abs(r),
      category = mech_category[temp_var],
      pred_id  = paste0(temp_var, "_L", lag)  # unique predictor identifier
    ) %>%
    filter(!is.na(r), n_eff >= 8)  # require minimum 8 observations
  
  # For each beach × recruit type, select top 2 from different categories
  selections <- cor_long %>%
    group_by(beach, recruit_type) %>%
    arrange(desc(abs_r)) %>%
    group_modify(~ {
      # Top 1: highest |r| overall
      top1 <- .x %>% slice(1)
      # Top 2: highest |r| from a DIFFERENT mechanistic category
      top2 <- .x %>%
        filter(category != top1$category[1]) %>%
        slice(1)
      bind_rows(
        top1 %>% mutate(rank = 1),
        top2 %>% mutate(rank = 2)
      )
    }) %>%
    ungroup() %>%
    select(beach, recruit_type, rank, pred_id, temp_var, lag, window,
           metric, category, r, p, n_eff)
  
  return(selections)
}

