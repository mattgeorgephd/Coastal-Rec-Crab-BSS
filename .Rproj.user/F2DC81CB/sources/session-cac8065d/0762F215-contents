# ── Heatmap helper function ──────────────────────────────────────────────
# Used for both best-lag and fixed-lag heatmaps.
# Takes a pre-processed dataframe with columns: beach, recruit_type, window,
#   metric, r, p, sig, lag, cell_label
make_heatmap <- function(plot_data, title_text, subtitle_text) {
  plot_data %>%
    mutate(
      window = factor(window, levels = rev(window_labels)),
      metric = factor(metric, levels = metric_levels,
                      labels = c("Min temp\n(upwelling proxy)",
                                 "Max temp\n(thermal stress)",
                                 "CUTI\n(transport)",
                                 "BEUTI\n(nutrients)",
                                 "Salinity\n(freshwater)",
                                 "Discharge\n(river flow)"))
    ) %>%
    ggplot(aes(x = metric, y = window, fill = r)) +
    geom_tile(color = "white", linewidth = 0.5) +
    geom_tile(data = . %>% filter(p < 0.05),
              aes(x = metric, y = window),
              fill = NA, color = "black", linewidth = 1.1) +
    geom_text(aes(label = cell_label), size = 2.4, color = "black", lineheight = 0.9) +
    scale_fill_gradient2(low = "steelblue", mid = "white", high = "firebrick",
                         midpoint = 0, limits = c(-1, 1), name = "Pearson r",
                         na.value = "grey90") +
    facet_grid(beach ~ recruit_type) +
    labs(x        = "Predictor metric",
         y        = "Seasonal window",
         title    = title_text,
         subtitle = subtitle_text) +
    my_theme +
    theme(legend.position  = "right",
          strip.background = element_rect(fill = "grey92", color = "black"),
          strip.text       = element_text(size = 10, color = "black"),
          axis.text.x      = element_text(size = 9))
}

# ── Helper: prepare long-format correlation data for heatmaps ────────────
prepare_cor_long <- function(cor_subset) {
  cor_subset %>%
    select(beach, lag, temp_var, window, metric, r_pre, r_rec, sig_pre, sig_rec, p_pre, p_rec) %>%
    pivot_longer(c(r_pre, r_rec),
                 names_to  = "recruit_type",
                 values_to = "r") %>%
    mutate(
      p            = ifelse(recruit_type == "r_pre", p_pre, p_rec),
      sig          = ifelse(recruit_type == "r_pre", sig_pre, sig_rec),
      recruit_type = recode(recruit_type, r_pre = "Pre-recruits", r_rec = "Recruits"),
      beach        = factor(beach, levels = beach_order, ordered = TRUE)
    )
}

for (ts in available_timescales) {
  
  ts_label <- switch(ts,
    "monthly"      = "Monthly",
    "half_monthly" = "Half-Monthly",
    "weekly"       = "Weekly"
  )
  
  cor_ts_long <- cor_all %>%
    filter(timescale == ts) %>%
    prepare_cor_long()
  
  # ── (a) Best-lag heatmap ───────────────────────────────────────────────
  # For each beach × recruit_type × predictor, select the lag with highest |r|.
  cor_best <- cor_ts_long %>%
    group_by(beach, recruit_type, temp_var, window, metric) %>%
    slice_max(abs(r), n = 1, with_ties = FALSE) %>%
    ungroup() %>%
    mutate(cell_label = paste0(sprintf("%.2f", r), sig, "\n(L", lag, ")"))
  
  p_heat_best <- make_heatmap(
    cor_best,
    paste0("Predictor–recruitment correlation (best lag) — ", ts_label, " resolution"),
    paste0("Black outline = p < 0.05 | Best of lags 0–", max_lag,
           " | Min/Max = temp; CUTI/BEUTI = upwelling; Sal = salinity")
  )
  
  print(p_heat_best)
  if (save_heatmaps) {
    ggsave(file.path(folder_name, ts,
                     paste0("heatmap_all_metrics_", ts, ".png")),
           plot = p_heat_best, width = 16, height = 18, dpi = 300)
  }
  
  # ── (b) Fixed-lag heatmaps — one per lag ───────────────────────────────
  # Shows correlation at a single specific lag across all windows and metrics.
  lag_subtitles <- c(
    "Lag 0: same year — current-year mortality / growth conditions",
    "Lag 1: 1 yr prior — juvenile survival and sub-adult growth",
    "Lag 2: 2 yr prior — larval supply (pre-recruits) / juvenile growth (recruits)",
    "Lag 3: 3 yr prior — spawning signal for fast-growing southern beaches",
    "Lag 4: 4 yr prior — spawning signal for mid-coast beaches",
    "Lag 5: 5 yr prior — spawning signal for slow-growing northern beaches"
  )
  
  for (lg in lag_range) {
    cor_lag <- cor_ts_long %>%
      filter(lag == lg) %>%
      mutate(cell_label = paste0(sprintf("%.2f", r), sig))
    
    p_heat_lag <- make_heatmap(
      cor_lag,
      paste0("Predictor–recruitment correlation at Lag ", lg, " — ", ts_label),
      paste0("Black outline = p < 0.05 | ", lag_subtitles[lg + 1])
    )
    
    print(p_heat_lag)
    if (save_heatmaps) {
      ggsave(file.path(folder_name, ts,
                       paste0("heatmap_lag", lg, "_", ts, ".png")),
             plot = p_heat_lag, width = 16, height = 18, dpi = 300)
    }
  }
  
  # ── (c) Best-lag-number heatmap ────────────────────────────────────────
  # Fill = which lag (0–5) produced the highest |r|.
  # Shows geographic gradient: shorter lags at southern beaches (faster
  # growth to recruit size), longer lags at northern beaches.
  # Text shows r, significance, and lag number.
  
  cor_best_num <- cor_ts_long %>%
    group_by(beach, recruit_type, temp_var, window, metric) %>%
    slice_max(abs(r), n = 1, with_ties = FALSE) %>%
    ungroup()
  
  p_heat_lagnum <- cor_best_num %>%
    mutate(
      window     = factor(window, levels = rev(window_labels)),
      metric     = factor(metric, levels = metric_levels,
                          labels = c("Min temp\n(upwelling proxy)",
                                     "Max temp\n(thermal stress)",
                                     "CUTI\n(transport)",
                                     "BEUTI\n(nutrients)",
                                     "Salinity\n(freshwater)",
                                     "Discharge\n(river flow)")),
      cell_label = paste0(sprintf("%.2f", r), sig, "\n(L", lag, ")"),
      sig_flag   = p < 0.05
    ) %>%
    ggplot(aes(x = metric, y = window, fill = lag)) +
    geom_tile(color = "white", linewidth = 0.5) +
    geom_tile(data = . %>% filter(sig_flag),
              aes(x = metric, y = window),
              fill = NA, color = "black", linewidth = 1.1) +
    geom_text(aes(label = cell_label), size = 2.4, color = "black", lineheight = 0.9) +
    scale_fill_viridis_c(option = "plasma", limits = c(0, max_lag),
                         breaks = lag_range, name = "Best lag\n(years)") +
    facet_grid(beach ~ recruit_type) +
    labs(x        = "Predictor metric",
         y        = "Seasonal window",
         title    = paste0("Optimal lag (years) for predictor–recruitment correlation — ", ts_label),
         subtitle = paste0("Fill = best lag (0–", max_lag,
                           "); text = r, significance | Black outline = p < 0.05")) +
    my_theme +
    theme(legend.position  = "right",
          strip.background = element_rect(fill = "grey92", color = "black"),
          strip.text       = element_text(size = 10, color = "black"),
          axis.text.x      = element_text(size = 9))
  
  print(p_heat_lagnum)
  if (save_heatmaps) {
    ggsave(file.path(folder_name, ts,
                     paste0("heatmap_best_lag_number_", ts, ".png")),
           plot = p_heat_lagnum, width = 16, height = 18, dpi = 300)
  }
}
