# ── Columbia River discharge (USGS gauge 14105700, The Dalles) ───────────
# Daily mean discharge in cubic feet per second (cfs), converted to m³/s.
# The Dalles is the last major gauge before the estuary and captures
# total basin runoff. Record extends from 1878; we use 1990–present.
# Higher discharge → stronger plume → lower nearshore salinity at Long Beach.

cat("\n--- Downloading Columbia River discharge from USGS ---\n")

# Check for cached file first (fastest path)
discharge_cache <- "02_data/Environmental Data/columbia_discharge.csv"

cr_discharge <- if (file.exists(discharge_cache)) {
  cat("  Loading from cached file:", discharge_cache, "\n")
  read.csv(discharge_cache) %>% mutate(date = as.Date(date))
} else {
  # Try multiple download methods to handle SSL/firewall issues
  result <- NULL
  
  # Method 1: read_waterdata_daily (requires httr2 >= 1.0.0)
  if (is.null(result)) {
    result <- tryCatch({
      cat("  Method 1: read_waterdata_daily()...\n")
      raw <- read_waterdata_daily(
        monitoring_location_id = "USGS-14105700",
        parameter_code = "00060", statistic_id = "00003",
        time = c("1990-01-01", as.character(Sys.Date()))
      )
      raw %>%
        sf::st_drop_geometry() %>%
        filter(parameter_code == "00060") %>%
        rename(discharge_cfs = value) %>%
        mutate(date = as.Date(time), year = year(date), month = month(date),
               discharge_cms = discharge_cfs * 0.0283168) %>%
        filter(!is.na(discharge_cfs)) %>%
        select(date, year, month, discharge_cfs, discharge_cms)
    }, error = function(e) { cat("    Failed:", conditionMessage(e), "\n"); NULL })
  }
  
  # Method 2: Direct download.file + jsonlite (often bypasses SSL issues)
  if (is.null(result)) {
    result <- tryCatch({
      cat("  Method 2: download.file + jsonlite...\n")
      api_url <- paste0(
        "https://api.waterdata.usgs.gov/ogcapi/v0/collections/daily/items",
        "?f=json&monitoring_location_id=USGS-14105700",
        "&parameter_code=00060&statistic_id=00003",
        "&time=1990-01-01/", format(Sys.Date(), "%Y-%m-%d"),
        "&limit=50000")
      tmp <- tempfile(fileext = ".json")
      download.file(api_url, tmp, mode = "wb", quiet = TRUE, method = "auto")
      raw_json <- jsonlite::fromJSON(tmp)
      unlink(tmp)
      props <- raw_json$features$properties
      props %>% as_tibble() %>%
        mutate(date = as.Date(time), year = year(date), month = month(date),
               discharge_cfs = as.numeric(value),
               discharge_cms = discharge_cfs * 0.0283168) %>%
        filter(!is.na(discharge_cfs)) %>%
        select(date, year, month, discharge_cfs, discharge_cms)
    }, error = function(e) { cat("    Failed:", conditionMessage(e), "\n"); NULL })
  }
  
  # Method 3: USGS tab-separated RDB format (different endpoint, simpler SSL)
  if (is.null(result)) {
    result <- tryCatch({
      cat("  Method 3: USGS waterdata RDB format...\n")
      rdb_url <- paste0(
        "https://waterdata.usgs.gov/nwis/dv?cb_00060=on&format=rdb",
        "&site_no=14105700&referred_module=sw",
        "&period=&begin_date=1990-01-01&end_date=", format(Sys.Date(), "%Y-%m-%d"))
      tmp <- tempfile(fileext = ".tsv")
      download.file(rdb_url, tmp, mode = "w", quiet = TRUE, method = "auto")
      lines <- readLines(tmp)
      unlink(tmp)
      # RDB files have comment lines starting with # and a header row
      data_start <- max(which(grepl("^#", lines))) + 1
      # Skip the format line (2nd header line)
      raw <- read.delim(text = paste(lines[c(data_start, (data_start+2):length(lines))],
                                      collapse = "\n"),
                         sep = "\t", stringsAsFactors = FALSE)
      # Column name varies; find the discharge column
      q_col <- grep("00060.*00003", names(raw), value = TRUE)[1]
      if (is.na(q_col)) stop("Discharge column not found in RDB output")
      raw %>%
        rename(discharge_cfs = !!q_col) %>%
        mutate(date = as.Date(datetime), year = year(date), month = month(date),
               discharge_cfs = as.numeric(discharge_cfs),
               discharge_cms = discharge_cfs * 0.0283168) %>%
        filter(!is.na(discharge_cfs)) %>%
        select(date, year, month, discharge_cfs, discharge_cms)
    }, error = function(e) { cat("    Failed:", conditionMessage(e), "\n"); NULL })
  }
  
  if (is.null(result)) {
    cat("\n  ALL download methods failed (likely SSL/firewall issue).\n")
    cat("  MANUAL FIX: Download discharge data via browser and save as:\n")
    cat("    ", discharge_cache, "\n")
    cat("  Browser URL (paste into browser, then File > Save As .csv):\n")
    cat("    https://waterdata.usgs.gov/nwis/dv?cb_00060=on&format=rdb&site_no=14105700&begin_date=1990-01-01\n")
    cat("  Or run in a fresh R session: install.packages('httr2') then re-run this script.\n")
  }
  result
}

