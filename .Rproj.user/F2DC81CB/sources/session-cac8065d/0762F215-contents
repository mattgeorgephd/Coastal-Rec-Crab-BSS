# ── Function to make a climatology spaghetti plot for a given temp metric ──
plot_clim_spaghetti <- function(metric_col, metric_label, title_suffix) {
  # Prepare yearly data
  yearly_dat <- wi %>%
    mutate(beach = factor(beach, levels = beach_order, ordered = TRUE)) %>%
    rename(temp_val = !!sym(metric_col))
  
  # Compute the climatology (mean across years)
  clim_dat <- yearly_dat %>%
    group_by(beach, month) %>%
    summarise(mean_t = mean(temp_val, na.rm = TRUE), .groups = "drop")
  
  # Shared y-axis limits across all beaches
  y_range <- range(c(yearly_dat$temp_val, clim_dat$mean_t), na.rm = TRUE)
  
  p <- ggplot() +
    # Individual year lines: muted color, thin, semi-transparent
    geom_line(data = yearly_dat,
              aes(x = month, y = temp_val, group = interaction(beach, year),
                  color = beach),
              alpha = 0.15, linewidth = 0.4) +
    # Bold average line per beach
    geom_line(data = clim_dat,
              aes(x = month, y = mean_t, color = beach, group = beach),
              linewidth = 1.5) +
    geom_point(data = clim_dat,
               aes(x = month, y = mean_t, color = beach),
               size = 2.5) +
    # Shade biologically important May–Aug window
    annotate("rect", xmin = 4.5, xmax = 8.5, ymin = -Inf, ymax = Inf,
             fill = "gold", alpha = 0.10) +
    annotate("text", x = 6.5, y = y_range[1] + 0.5,
             label = "May–Aug\n(spawning–settlement)",
             size = 3.5, color = "goldenrod4", fontface = "italic") +
    scale_x_continuous(breaks = 1:12, labels = month.abb) +
    scale_color_manual(values = beach_colors, name = "Beach (N → S)") +
    coord_cartesian(ylim = y_range + c(-0.5, 0.5)) +
    labs(x     = "Month",
         y     = paste0(metric_label, " water temperature (°C)"),
         title = paste("Seasonal temperature climatology —", title_suffix),
         subtitle = "Faint lines = individual years; bold lines = long-term average") +
    my_theme +
    theme(legend.position = "right")
  
  return(p)
}

