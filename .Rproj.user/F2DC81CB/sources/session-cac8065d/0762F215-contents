## 4c. Weekly IDW blending (from daily data)
```{r}
# ── Aggregate daily data to weekly summaries ──────────────────────────────
# Uses ISO week numbers via lubridate::isoweek(). Each week is identified by
# year + week number. Aggregation computes mean, min, max, and SD of daily
# temperatures within each station × year × week.
#
# IMPORTANT: lubridate masks base::date and also provides day(), month(), year()
# functions that can collide with column names in the daily data. We use
# lubridate extraction functions on the date_col to derive year/month/week
# rather than assuming those columns exist in the raw data.

# Diagnostic: print column names so we can confirm what's available
cat("\n--- wtmp_daily columns ---\n")
cat(paste(names(wtmp_daily), collapse = ", "), "\n")

# ── Step 1: Build a proper Date column + derive year/month/week ───────────
# The daily data may have a 'date' column, year/month/day columns, or both.
# We always derive wk_year, wk_month, week, and iso_year from the date using
# lubridate functions to avoid any column-name ambiguity.

if ("date" %in% names(wtmp_daily) && inherits(wtmp_daily$date, c("Date", "POSIXct", "POSIXlt"))) {
  # Date column already exists and is a proper date type — use it directly
  cat("Using existing 'date' column from wtmp_daily\n")
  wtmp_daily <- wtmp_daily %>%
    mutate(
      date_col = as.Date(.data$date),
      wk_year  = year(date_col),      # extract year from date
      wk_month = month(date_col),     # extract month from date
      week     = isoweek(date_col),
      iso_year = isoyear(date_col)
    )
} else if (all(c("year", "month", "day") %in% names(wtmp_daily))) {
  # Construct date from year/month/day columns
  # Use .data$ to avoid lubridate masking the 'day' column
  cat("Constructing date from year/month/day columns\n")
  wtmp_daily <- wtmp_daily %>%
    mutate(
      date_col = as.Date(paste(.data$year, .data$month, .data$day, sep = "-")),
      wk_year  = year(date_col),
      wk_month = month(date_col),
      week     = isoweek(date_col),
      iso_year = isoyear(date_col)
    )
} else {
  # Fallback: try to find any date-like column
  date_candidates <- names(wtmp_daily)[sapply(wtmp_daily, function(x) inherits(x, c("Date", "POSIXct")))]
  if (length(date_candidates) > 0) {
    cat("Using date candidate column:", date_candidates[1], "\n")
    wtmp_daily <- wtmp_daily %>%
      mutate(
        date_col = as.Date(.data[[date_candidates[1]]]),
        wk_year  = year(date_col),
        wk_month = month(date_col),
        week     = isoweek(date_col),
        iso_year = isoyear(date_col)
      )
  } else {
    stop("Cannot find or construct a date column in wtmp_daily. ",
         "Available columns: ", paste(names(wtmp_daily), collapse = ", "))
  }
}

# ── Step 2: Identify the temperature value column ─────────────────────────
# The daily data might call the temperature column 'wtmp', 'WTMP', 'temp', etc.
temp_col_candidates <- c("wtmp", "WTMP", "temp", "temperature", "wtmp_mean", "value")
temp_col <- intersect(temp_col_candidates, names(wtmp_daily))
if (length(temp_col) == 0) {
  cat("WARNING: No recognized temperature column found. Candidates tried:",
      paste(temp_col_candidates, collapse = ", "), "\n")
  cat("Available columns:", paste(names(wtmp_daily), collapse = ", "), "\n")
  temp_col <- NA_character_
} else {
  temp_col <- temp_col[1]
  cat("Using temperature column:", temp_col, "\n")
}

# ── Step 3: Weekly aggregation per station ────────────────────────────────
if (!is.na(temp_col)) {
  wtmp_weekly <- wtmp_daily %>%
    rename(temp_val = !!sym(temp_col)) %>%
    group_by(station, iso_year, week, latitude, longitude) %>%
    summarise(
      wtmp_mean = mean(temp_val, na.rm = TRUE),
      wtmp_min  = min(temp_val,  na.rm = TRUE),
      wtmp_max  = max(temp_val,  na.rm = TRUE),
      wtmp_sd   = sd(temp_val,   na.rm = TRUE),
      n_days    = sum(!is.na(temp_val)),
      # Dominant month: which month contributes the most days to this week
      month     = as.integer(names(which.max(table(wk_month)))),
      .groups   = "drop"
    ) %>%
    rename(year = iso_year) %>%
    # Replace Inf/-Inf from min/max on all-NA groups with NA
    mutate(
      across(c(wtmp_min, wtmp_max), ~ifelse(is.infinite(.), NA_real_, .)),
      wtmp_sd = ifelse(is.nan(wtmp_sd), NA_real_, wtmp_sd)
    ) %>%
    # Require at least 4 days for a valid weekly summary
    filter(n_days >= 4)
  
  cat("Weekly aggregation complete:", nrow(wtmp_weekly), "station-weeks\n")
} else {
  wtmp_weekly <- NULL
  cat("WARNING: Skipping weekly aggregation — no temperature column identified\n")
}

# ── Step 4: IDW blending for weekly resolution ────────────────────────────
# Only proceeds if weekly aggregation succeeded above.

wi_wk <- NULL   # initialize as NULL; downstream code checks for this

if (!is.null(wtmp_weekly) && nrow(wtmp_weekly) > 0) {
  
  st_wk <- wtmp_weekly %>%
    filter(!is.na(latitude), !is.na(longitude)) %>%
    distinct(station, latitude, longitude)
  
  bsd_wk <- bc %>%
    rowwise() %>%
    mutate(
      ds = list(st_wk %>% mutate(d = hav(blat, blon, latitude, longitude)))
    ) %>%
    unnest(ds) %>%
    select(beach, station, d) %>%
    ungroup()
  
  aywk <- wtmp_weekly %>% distinct(year, week)
  
  wi_wk <- bc %>%
    select(beach) %>%
    cross_join(aywk) %>%
    left_join(bsd_wk, by = "beach", relationship = "many-to-many") %>%
    left_join(
      wtmp_weekly %>% select(station, year, week, month, wtmp_mean, wtmp_min, wtmp_max, wtmp_sd),
      by = c("station", "year", "week"), relationship = "many-to-many"
    ) %>%
    filter(!is.na(wtmp_mean), d <= max_dist) %>%
    mutate(w = 1 / d ^ idwp) %>%
    group_by(beach, year, week) %>%
    summarise(
      wk_mean = weighted.mean(wtmp_mean, w = w),
      wk_min  = weighted.mean(wtmp_min,  w = w),
      wk_max  = weighted.mean(wtmp_max,  w = w),
      wk_sd   = sqrt(weighted.mean(wtmp_sd^2, w = w)),
      month   = as.integer(names(which.max(table(month)))),
      ns      = n(),
      dom_stn = station[which.max(w)],
      .groups = "drop"
    )
  
  # Weekly completeness check
  cat("\n--- Weekly IDW completeness ---\n")
  wi_wk %>%
    group_by(beach) %>%
    summarise(
      nf = n(),
      ne = n_distinct(wtmp_weekly$year) * 52,
      pc = round(nf / ne, 3),
      an = round(mean(ns), 1),
      .groups = "drop"
    ) %>%
    print()
  
  # Station attribution (weekly)
  cat("\n--- Dominant stations by beach (weekly) ---\n")
  wi_wk %>%
    group_by(beach) %>%
    summarise(
      primary_station_id = names(which.max(table(dom_stn))),
      .groups = "drop"
    ) %>%
    left_join(stations %>% select(station, Name), by = c("primary_station_id" = "station")) %>%
    rename(primary_station_name = Name) %>%
    print()
  
} else {
  cat("\n--- Weekly IDW: SKIPPED (daily aggregation failed or produced no data) ---\n")
  cat("The analysis will proceed with monthly and half-monthly timescales only.\n")
}
```

## 4d. Salinity IDW blending (monthly from daily)

```{r}
# ── IDW blended salinity at each beach ────────────────────────────────────
# Strategy: Only blend salinity from stations within 40 km of a beach.
# This ensures that salinity values represent genuinely local oceanographic
# conditions rather than extrapolating across water mass boundaries.
#
# With current station coverage (3 Westport shelf buoys + SATURN-02):
#   Copalis / Mocrocks  → Westport buoys within ~5–12 km  → good local data
#   Twin Harbors        → Westport buoys within ~33–36 km  → acceptable
#   Long Beach          → SATURN-02 within ~21 km (if available) → plume salinity
#   Kalaloch            → nearest station ~53 km → excluded (NA)
#
# FUTURE-PROOFING: If new buoy data is added to DailySalt.xlsx (or bound
# from ERDDAP as with SATURN-02), the code will automatically detect it,
# compute distances, and include it in the IDW blend for nearby beaches.
# No code changes are needed — just add rows to the input data.

sal_max_dist <- 40  # km — only use stations representing local conditions

# ── 1. Aggregate daily salinity to monthly per station ─────────────────────
salt_monthly <- salt_daily %>%
  group_by(station, latitude, longitude, year, month) %>%
  summarise(
    sal_mean = mean(sal_mean, na.rm = TRUE),
    sal_min  = mean(sal_min,  na.rm = TRUE),
    sal_max  = mean(sal_max,  na.rm = TRUE),
    n_days   = n(),
    .groups  = "drop"
  ) %>%
  # Require at least 10 days for a valid monthly summary
 filter(n_days >= 10)

cat("\n--- Monthly salinity aggregation ---\n")
cat("Station-months:", nrow(salt_monthly), "\n")

# ── 2. Distance lookup: beach to salinity stations ─────────────────────────
st_sal <- salt_monthly %>%
  filter(!is.na(latitude), !is.na(longitude)) %>%
  distinct(station, latitude, longitude)

bsd_sal <- bc %>%
  rowwise() %>%
  mutate(
    ds = list(st_sal %>% mutate(d = hav(blat, blon, latitude, longitude)))
  ) %>%
  unnest(ds) %>%
  select(beach, station, d) %>%
  ungroup()

cat("\n--- Salinity station distances to beaches ---\n")
bsd_sal %>%
  mutate(d = round(d, 1)) %>%
  pivot_wider(names_from = station, values_from = d) %>%
  print()

# ── 3. Identify which beaches have at least one station within range ───────
beaches_with_sal <- bsd_sal %>%
  filter(d <= sal_max_dist) %>%
  distinct(beach) %>%
  pull(beach)

beaches_without_sal <- setdiff(beach_order, beaches_with_sal)

cat("\n--- Salinity coverage at", sal_max_dist, "km radius ---\n")
cat("Beaches WITH  local salinity:", paste(beaches_with_sal, collapse = ", "), "\n")
if (length(beaches_without_sal) > 0) {
  cat("Beaches WITHOUT local salinity:", paste(beaches_without_sal, collapse = ", "), "\n")
  cat("  (nearest station distances for excluded beaches:)\n")
  bsd_sal %>%
    filter(beach %in% beaches_without_sal) %>%
    group_by(beach) %>%
    summarise(nearest_station = station[which.min(d)],
              nearest_km = round(min(d), 1),
              .groups = "drop") %>%
    print()
}

# ── 4. IDW blending (only for beaches with stations in range) ─────────────
aym_sal <- salt_monthly %>% distinct(year, month)

if (length(beaches_with_sal) > 0) {
  wi_sal <- bc %>%
    filter(beach %in% beaches_with_sal) %>%
    select(beach) %>%
    cross_join(aym_sal) %>%
    left_join(bsd_sal, by = "beach", relationship = "many-to-many") %>%
    left_join(
      salt_monthly %>% select(station, year, month, sal_mean, sal_min, sal_max),
      by = c("station", "year", "month"), relationship = "many-to-many"
    ) %>%
    filter(!is.na(sal_mean), d <= sal_max_dist) %>%
    mutate(w = 1 / d ^ idwp) %>%
    group_by(beach, year, month) %>%
    summarise(
      sal      = weighted.mean(sal_mean, w = w),
      sal_lo   = weighted.mean(sal_min,  w = w),
      sal_hi   = weighted.mean(sal_max,  w = w),
      ns_sal   = n(),
      dom_stn_sal = station[which.max(w)],
      .groups  = "drop"
    )
} else {
  # No beaches have salinity coverage — create empty frame
  wi_sal <- tibble(beach = character(), year = integer(), month = integer(),
                   sal = numeric(), sal_lo = numeric(), sal_hi = numeric(),
                   ns_sal = integer(), dom_stn_sal = character())
}

# ── Completeness diagnostic ────────────────────────────────────────────────
cat("\n--- Salinity IDW completeness ---\n")
if (nrow(wi_sal) > 0) {
  wi_sal %>%
    group_by(beach) %>%
    summarise(
      n_months   = n(),
      year_range = paste(min(year), max(year), sep = "–"),
      avg_stns   = round(mean(ns_sal), 1),
      dom_stn    = names(which.max(table(dom_stn_sal))),
      min_dist   = round(min(bsd_sal$d[bsd_sal$beach == first(beach) &
                                        bsd_sal$d <= sal_max_dist]), 1),
      .groups    = "drop"
    ) %>%
    print()
} else {
  cat("No beaches have salinity stations within", sal_max_dist, "km\n")
}

if (length(beaches_without_sal) > 0) {
  cat("\nNote:", paste(beaches_without_sal, collapse = " and "),
      "will have NA for all salinity predictors.\n",
      "Add closer buoy data to DailySalt.xlsx to enable salinity at these beaches.\n")
}
```


