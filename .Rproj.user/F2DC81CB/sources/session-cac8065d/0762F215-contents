# ── Fit candidate models for each beach × recruit type ──────────────────
# ═════════════════════════════════════════════════════════════════════════

model_results <- list()  # store all results

for (bch in beach_order) {
  for (rtype in c("Pre-recruits", "Recruits")) {
    
    key <- paste(bch, rtype, sep = " | ")
    
    # Build dataset
    md <- build_model_data(bch, rtype, pred_selections, rl_monthly, rec)
    if (is.null(md)) next
    
    # Remove rows with NA in predictors
    has_env2 <- "env2" %in% names(md) && any(!is.na(md$env2))
    
    # Candidate formulas
    formulas <- list(
      "Null"           = log_resp ~ 1,
      "Env1"           = log_resp ~ env1,
      "Env1 + DD"      = log_resp ~ env1 + log_resp_lag1
    )
    
    if (has_env2) {
      formulas[["Env1 + Env2"]]      <- log_resp ~ env1 + env2
      formulas[["Env1 + Env2 + DD"]] <- log_resp ~ env1 + env2 + log_resp_lag1
      formulas[["Env2"]]             <- log_resp ~ env2
      formulas[["Env2 + DD"]]        <- log_resp ~ env2 + log_resp_lag1
    }
    
    # Also test density-dependence alone
    formulas[["DD only"]] <- log_resp ~ log_resp_lag1
    
    # Fit all candidate models
    model_fits  <- list()
    model_stats <- list()
    
    for (mname in names(formulas)) {
      
      # Determine which columns are needed
      needed_vars <- all.vars(formulas[[mname]])
      md_complete <- md %>% select(sy, all_of(needed_vars)) %>% na.omit()
      
      if (nrow(md_complete) < 8) next  # need minimum 8 observations
      
      # Fit model
      fit <- tryCatch(lm(formulas[[mname]], data = md_complete), error = function(e) NULL)
      if (is.null(fit)) next
      
      # In-sample stats
      r2      <- summary(fit)$r.squared
      adj_r2  <- summary(fit)$adj.r.squared
      aicc    <- tryCatch(AICc(fit), error = function(e) NA)
      n_obs   <- nobs(fit)
      k_params <- length(coef(fit))
      
      # LOOCV
      cv_loo  <- tryCatch(loocv(formulas[[mname]], md_complete),
                           error = function(e) list(q2 = NA, rmse = NA, predicted = NULL))
      
      # Rolling-origin CV
      cv_roll <- tryCatch(rolling_cv(formulas[[mname]], md_complete),
                           error = function(e) list(q2 = NA, rmse = NA, predicted = NULL))
      
      model_fits[[mname]] <- fit
      model_stats[[mname]] <- tibble(
        model     = mname,
        n         = n_obs,
        k         = k_params,
        R2        = round(r2, 3),
        adj_R2    = round(adj_r2, 3),
        AICc      = round(aicc, 1),
        Q2_LOOCV  = round(cv_loo$q2, 3),
        RMSE_LOOCV = round(cv_loo$rmse, 3),
        Q2_rolling = round(cv_roll$q2, 3),
        RMSE_rolling = round(cv_roll$rmse, 3)
      )
    }
    
    if (length(model_stats) == 0) next
    
    stats_df <- bind_rows(model_stats) %>%
      mutate(delta_AICc = round(AICc - min(AICc, na.rm = TRUE), 1)) %>%
      arrange(AICc)
    
    model_results[[key]] <- list(
      beach        = bch,
      recruit_type = rtype,
      model_data   = md,
      pred1_label  = attr(md, "pred1_label"),
      pred2_label  = attr(md, "pred2_label"),
      pred1_id     = attr(md, "pred1_id"),
      pred2_id     = attr(md, "pred2_id"),
      formulas     = formulas,
      fits         = model_fits,
      stats        = stats_df,
      best_model   = stats_df$model[1]  # lowest AICc
    )
    
    cat("\n--- ", key, " ---\n")
    print(stats_df, n = Inf)
  }
}
