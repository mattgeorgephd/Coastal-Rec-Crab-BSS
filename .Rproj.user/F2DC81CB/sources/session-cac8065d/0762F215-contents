# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 7: SEASONAL PREDICTOR INDICES (ALL TIMESCALES + UPWELLING + SALINITY)
# ═══════════════════════════════════════════════════════════════════════════════

## Seasonal windows: Spring (Mar–May), Spawn (May–Jun), Larval (Jun–Jul),
## Settlement (Jul–Aug), Growth (Sep–Oct)
##
## Metrics: Min temp (upwelling proxy), Max temp (thermal stress),
##          CUTI (coastal upwelling transport), BEUTI (biologically effective
##          upwelling transport), Salinity (freshwater/upwelling balance),
##          Discharge (Columbia River flow — freshwater influence)

```{r}
# ── Strategy: merge ALL predictor data into a single long-format table ────
# per timescale (beach × year × month) BEFORE computing seasonal indices.
# Upwelling (BEUTI/CUTI) is coastwide — joining by year+month replicates
# values across beaches naturally. Salinity is beach-specific from IDW.
# Discharge is coastwide (same Columbia River value for all beaches).

# ── Function: compute ALL seasonal indices from merged long data ──────────
# Expects columns: beach, year, month, t_min, t_max, beuti, cuti, sal, q_mean
# Returns one row per beach × year with 30 columns (5 windows × 6 metrics).
compute_seasonal_indices <- function(merged_long) {
  merged_long %>%
    group_by(beach, year) %>%
    summarise(
      # ── Minimum temperature windows (upwelling proxy) ───────────────────
      t_spring_min = mean(t_min[month %in% 3:5],  na.rm = TRUE),
      t_spawn_min  = mean(t_min[month %in% 5:6],  na.rm = TRUE),
      t_larval_min = mean(t_min[month %in% 6:7],  na.rm = TRUE),
      t_settle_min = mean(t_min[month %in% 7:8],  na.rm = TRUE),
      t_growth_min = mean(t_min[month %in% 9:10], na.rm = TRUE),
      # ── Maximum temperature windows (thermal stress proxy) ──────────────
      t_spring_max = mean(t_max[month %in% 3:5],  na.rm = TRUE),
      t_spawn_max  = mean(t_max[month %in% 5:6],  na.rm = TRUE),
      t_larval_max = mean(t_max[month %in% 6:7],  na.rm = TRUE),
      t_settle_max = mean(t_max[month %in% 7:8],  na.rm = TRUE),
      t_growth_max = mean(t_max[month %in% 9:10], na.rm = TRUE),
      # ── BEUTI windows (biologically effective upwelling) ────────────────
      beuti_spring = mean(beuti[month %in% 3:5],  na.rm = TRUE),
      beuti_spawn  = mean(beuti[month %in% 5:6],  na.rm = TRUE),
      beuti_larval = mean(beuti[month %in% 6:7],  na.rm = TRUE),
      beuti_settle = mean(beuti[month %in% 7:8],  na.rm = TRUE),
      beuti_growth = mean(beuti[month %in% 9:10], na.rm = TRUE),
      # ── CUTI windows (coastal upwelling transport) ─────────────────────
      cuti_spring  = mean(cuti[month %in% 3:5],   na.rm = TRUE),
      cuti_spawn   = mean(cuti[month %in% 5:6],   na.rm = TRUE),
      cuti_larval  = mean(cuti[month %in% 6:7],   na.rm = TRUE),
      cuti_settle  = mean(cuti[month %in% 7:8],   na.rm = TRUE),
      cuti_growth  = mean(cuti[month %in% 9:10],  na.rm = TRUE),
      # ── Salinity windows ────────────────────────────────────────────────
      sal_spring   = mean(sal[month %in% 3:5],    na.rm = TRUE),
      sal_spawn    = mean(sal[month %in% 5:6],    na.rm = TRUE),
      sal_larval   = mean(sal[month %in% 6:7],    na.rm = TRUE),
      sal_settle   = mean(sal[month %in% 7:8],    na.rm = TRUE),
      sal_growth   = mean(sal[month %in% 9:10],   na.rm = TRUE),
      # ── Columbia River discharge windows ────────────────────────────────
      q_spring     = mean(q_mean[month %in% 3:5],  na.rm = TRUE),
      q_spawn      = mean(q_mean[month %in% 5:6],  na.rm = TRUE),
      q_larval     = mean(q_mean[month %in% 6:7],  na.rm = TRUE),
      q_settle     = mean(q_mean[month %in% 7:8],  na.rm = TRUE),
      q_growth     = mean(q_mean[month %in% 9:10], na.rm = TRUE),
      .groups      = "drop"
    ) %>%
    # Replace NaN (from windows with no data) with NA
    mutate(across(where(is.numeric), ~ifelse(is.nan(.), NA_real_, .)))
}

# ── Helper: merge upwelling + salinity + discharge into temp long table ───
# upwell_monthly has beach × year × month (latitude-matched per beach);
# wi_sal has beach × year × month (IDW-blended salinity);
# discharge_monthly has year × month (coastwide, replicated to all beaches)
merge_all_predictors <- function(temp_long, upwell_mo, sal_mo, q_mo = NULL) {
  out <- temp_long %>%
    left_join(upwell_mo %>% select(beach, year, month, beuti, cuti),
              by = c("beach", "year", "month")) %>%
    left_join(sal_mo %>% select(beach, year, month, sal),
              by = c("beach", "year", "month"))
  
  # Add discharge (coastwide — join by year+month only, replicates to all beaches)
  if (!is.null(q_mo)) {
    out <- out %>%
      left_join(q_mo %>% select(year, month, q_mean),
                by = c("year", "month"))
  } else {
    out <- out %>% mutate(q_mean = NA_real_)
  }
  out
}

