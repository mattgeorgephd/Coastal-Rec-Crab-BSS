# ── SATURN-02 salinity (CMOP/CRITFC, NDBC 46096) ────────────────────────
# Location: 46.173°N, 124.127°W — Columbia River entrance / plume station.
# ~21 km from Long Beach. Measures plume-influenced salinity, which is the
# mechanistically relevant variable for Long Beach (Columbia plume dynamics).
# Data from CMOP ERDDAP server (data.stccmop.org); CT sensor at 35 m depth.
# Dataset: saturn02_3500_P_CT (conductivity-temperature instrument).

cat("\n--- Downloading SATURN-02 salinity from CMOP ERDDAP ---\n")

saturn02_cache <- "02_data/Environmental Data/saturn02_salinity.csv"

# Helper: process raw ERDDAP CSV into daily salinity format
process_saturn02_raw <- function(raw_csv_path) {
  raw <- read.csv(raw_csv_path, skip = 1, stringsAsFactors = FALSE)
  names(raw) <- c("time", "salinity")
  raw %>%
    mutate(salinity = as.numeric(salinity)) %>%
    filter(!is.na(salinity), salinity > 0, salinity < 40) %>%
    mutate(datetime = as.POSIXct(time, format = "%Y-%m-%dT%H:%M:%SZ", tz = "UTC"),
           date = as.Date(datetime), year = year(date), month = month(date),
           station = "SATURN-02", latitude = 46.17345, longitude = -124.12717) %>%
    group_by(station, latitude, longitude, date, year, month) %>%
    summarise(sal_mean = mean(salinity, na.rm = TRUE),
              sal_min = min(salinity, na.rm = TRUE),
              sal_max = max(salinity, na.rm = TRUE), .groups = "drop")
}

erddap_url <- paste0(
  "https://data.stccmop.org/erddap/tabledap/saturn02_3500_P_CT.csv",
  "?time,sea_water_practical_salinity",
  "&time>=2008-01-01T00:00:00Z",
  "&sea_water_practical_salinity>0",
  "&sea_water_practical_salinity<40")

saturn02_sal <- if (file.exists(saturn02_cache)) {
  cat("  Loading from cached file:", saturn02_cache, "\n")
  cached <- read.csv(saturn02_cache, stringsAsFactors = FALSE)
  if ("sal_mean" %in% names(cached)) {
    # Already in processed daily format
    cached %>% mutate(date = as.Date(date))
  } else if ("time" %in% names(cached) || "sea_water_practical_salinity" %in% names(cached)) {
    # Raw ERDDAP format — process and re-save
    cat("  Detected raw ERDDAP format — processing to daily...\n")
    processed <- process_saturn02_raw(saturn02_cache)
    write.csv(processed, saturn02_cache, row.names = FALSE)
    cat("  Re-saved in daily format.\n")
    processed
  } else {
    cat("  WARNING: Unrecognized format in cached file. Columns:", paste(names(cached), collapse = ", "), "\n")
    NULL
  }
} else {
  result <- NULL
  tmp <- tempfile(fileext = ".csv")
  
  # Method 1: system curl with -k (skip SSL verification)
  if (is.null(result)) {
    result <- tryCatch({
      cat("  Method 1: system curl -k (skip SSL verify)...\n")
      cmd <- sprintf('curl -k -s -o "%s" "%s"', tmp, erddap_url)
      exit_code <- system(cmd)
      if (exit_code != 0) stop("curl returned exit code ", exit_code)
      if (!file.exists(tmp) || file.size(tmp) < 100) stop("Downloaded file is empty or missing")
      process_saturn02_raw(tmp)
    }, error = function(e) { cat("    Failed:", conditionMessage(e), "\n"); NULL })
  }
  
  # Method 2: download.file with curl method (uses R's curl binding)
  if (is.null(result)) {
    result <- tryCatch({
      cat("  Method 2: download.file (curl method)...\n")
      download.file(erddap_url, tmp, mode = "w", quiet = TRUE, method = "curl",
                    extra = "-k")  # -k = insecure, skips SSL verify
      if (!file.exists(tmp) || file.size(tmp) < 100) stop("Downloaded file is empty")
      process_saturn02_raw(tmp)
    }, error = function(e) { cat("    Failed:", conditionMessage(e), "\n"); NULL })
  }
  
  # Method 3: download.file with wininet (Windows only — uses OS SSL stack)
  if (is.null(result) && .Platform$OS.type == "windows") {
    result <- tryCatch({
      cat("  Method 3: download.file (wininet method, Windows SSL)...\n")
      download.file(erddap_url, tmp, mode = "w", quiet = TRUE, method = "wininet")
      if (!file.exists(tmp) || file.size(tmp) < 100) stop("Downloaded file is empty")
      process_saturn02_raw(tmp)
    }, error = function(e) { cat("    Failed:", conditionMessage(e), "\n"); NULL })
  }
  
  # Method 4: Direct read.csv (R's internal HTTP/SSL)
  if (is.null(result)) {
    result <- tryCatch({
      cat("  Method 4: read.csv (R internal SSL)...\n")
      process_saturn02_raw(erddap_url)
    }, error = function(e) { cat("    Failed:", conditionMessage(e), "\n"); NULL })
  }
  
  unlink(tmp)
  
  if (is.null(result)) {
    cat("\n  ALL download methods failed (SSL issue with data.stccmop.org).\n")
    cat("  MANUAL FIX — run this in a system terminal (not R), then re-run script:\n")
    cat('  curl -k "', erddap_url, '" -o saturn02_raw.csv\n', sep = "")
    cat("  Then in R:\n")
    cat('  raw <- read.csv("saturn02_raw.csv", skip = 1)\n')
    cat('  # ... or just copy saturn02_raw.csv to:\n')
    cat("    ", saturn02_cache, "\n")
    cat("  (The script will auto-detect and use it on next run.)\n")
  }
  result
}

if (!is.null(saturn02_sal)) {
  cat("SATURN-02 salinity loaded:", nrow(saturn02_sal), "daily records\n")
  cat("Date range:", as.character(range(saturn02_sal$date)), "\n")
  cat("Mean salinity range:", round(range(saturn02_sal$sal_mean, na.rm = TRUE), 1), "PSU\n")
  # Cache for offline use
  if (!file.exists(saturn02_cache)) {
    write.csv(saturn02_sal, saturn02_cache, row.names = FALSE)
    cat("  Cached to:", saturn02_cache, "\n")
  }
  
  # ── Bind SATURN-02 into salt_daily so IDW blending picks it up ──────────
  # Format to match salt_daily columns
  saturn02_for_bind <- saturn02_sal %>%
    select(station, latitude, longitude, date, year, month,
           sal_mean, sal_min, sal_max)
  
  salt_daily <- bind_rows(salt_daily, saturn02_for_bind)
  cat("SATURN-02 appended to salt_daily. Total rows:", nrow(salt_daily), "\n")
  cat("Stations now:", paste(unique(salt_daily$station), collapse = ", "), "\n")
} else {
  cat("SATURN-02: NOT AVAILABLE — Long Beach remains without local salinity\n")
