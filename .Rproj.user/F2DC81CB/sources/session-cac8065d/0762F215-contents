# ═════════════════════════════════════════════════════════════════════════
# ── Diagnostic plots for best models ────────────────────────────────────
# ═════════════════════════════════════════════════════════════════════════
# Four-panel diagnostic for each beach × recruit type:
#   (1) Observed vs predicted (in-sample + LOOCV)
#   (2) Residuals vs fitted
#   (3) Residual ACF
#   (4) Q-Q plot

diag_plots <- list()

for (key in names(model_results)) {
  
  res   <- model_results[[key]]
  bfit  <- res$fits[[res$best_model]]
  md    <- res$model_data
  bch   <- res$beach
  rtype <- res$recruit_type
  
  if (is.null(bfit)) next
  
  # Get complete data used by the model
  needed <- all.vars(res$formulas[[res$best_model]])
  md_complete <- md %>% select(sy, all_of(needed)) %>% na.omit()
  
  # In-sample predictions
  md_complete$fitted   <- fitted(bfit)
  md_complete$residual <- residuals(bfit)
  
  # LOOCV predictions
  cv_loo <- tryCatch(loocv(res$formulas[[res$best_model]], md_complete),
                      error = function(e) list(predicted = rep(NA, nrow(md_complete))))
  md_complete$loo_pred <- cv_loo$predicted
  
  # Panel 1: Observed vs Predicted
  p1 <- md_complete %>%
    select(sy, Observed = log_resp, Fitted = fitted, LOOCV = loo_pred) %>%
    pivot_longer(c(Fitted, LOOCV), names_to = "type", values_to = "predicted") %>%
    ggplot(aes(x = predicted, y = Observed, color = type, shape = type)) +
    geom_abline(intercept = 0, slope = 1, lty = 2, color = "grey50") +
    geom_point(size = 3, alpha = 0.8) +
    scale_color_manual(values = c(Fitted = "firebrick", LOOCV = "steelblue")) +
    labs(x = "Predicted log(abundance + 1)", y = "Observed log(abundance + 1)",
         title = "Observed vs Predicted", color = NULL, shape = NULL) +
    my_theme + theme(legend.position = "bottom")
  
  # Panel 2: Residuals vs fitted
  p2 <- md_complete %>%
    ggplot(aes(x = fitted, y = residual)) +
    geom_hline(yintercept = 0, lty = 2, color = "grey50") +
    geom_point(size = 3, color = "steelblue", alpha = 0.7) +
    geom_smooth(method = "loess", se = FALSE, color = "firebrick",
                linewidth = 0.8, span = 1) +
    labs(x = "Fitted values", y = "Residuals",
         title = "Residuals vs Fitted") +
    my_theme
  
  # Panel 3: Residual ACF
  acf_data <- tidy_acf(md_complete$residual, lag_max = 8)
  p3 <- if (!is.null(acf_data)) {
    acf_data %>%
      filter(lag > 0) %>%
      ggplot(aes(x = lag, y = acf)) +
      geom_hline(yintercept = 0) +
      geom_hline(yintercept = c(-1, 1) * acf_data$ci[1], lty = 2, color = "blue") +
      geom_col(fill = "steelblue", width = 0.6) +
      labs(x = "Lag (years)", y = "ACF", title = "Residual ACF") +
      my_theme
  } else {
    ggplot() + annotate("text", x = 0.5, y = 0.5, label = "Insufficient data") + my_theme
  }
  
  # Panel 4: Q-Q plot
  p4 <- md_complete %>%
    mutate(
      theoretical = qqnorm(residual, plot.it = FALSE)$x,
      sample      = qqnorm(residual, plot.it = FALSE)$y
    ) %>%
    ggplot(aes(x = theoretical, y = sample)) +
    geom_abline(intercept = mean(md_complete$residual),
                slope = sd(md_complete$residual), lty = 2, color = "grey50") +
    geom_point(size = 3, color = "steelblue", alpha = 0.7) +
    labs(x = "Theoretical quantiles", y = "Sample quantiles",
         title = "Normal Q-Q") +
    my_theme
  
  # Combine panels
  p_diag <- (p1 | p2) / (p3 | p4) +
    patchwork::plot_annotation(
      title    = paste0(bch, " — ", rtype),
      subtitle = paste0("Best model: ", res$best_model,
                        " | R² = ", round(summary(bfit)$r.squared, 3),
                        " | Q²(LOOCV) = ", round(cv_loo$q2, 3)),
      theme    = theme(plot.title = element_text(size = 16, face = "bold"))
    )
  
  diag_plots[[key]] <- p_diag
}

for (key in names(diag_plots)) {
  print(diag_plots[[key]])
  
  if (save_models) {
    res <- model_results[[key]]
    fname <- paste0("model_diagnostics_",
                    gsub(" ", "_", tolower(res$beach)), "_",
                    gsub("-", "", tolower(res$recruit_type)), ".png")
    ggsave(file.path(folder_name, "models", fname),
           plot = diag_plots[[key]], width = 14, height = 10, dpi = 300)
  }
}
