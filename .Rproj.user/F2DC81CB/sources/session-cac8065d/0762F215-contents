## IDW parameters and beach coordinates

```{r}
# Estimates water temperature at each razor clam beach by inverse-distance
# weighting (IDW) of nearby buoys within max_dist km. Computes blended mean,
# min, and max temperature simultaneously so downstream analyses can compare
# which metric has the strongest relationship with recruitment.

max_dist <- 50   # km radius — stations beyond this are excluded from blending
idwp     <- 3     # IDW power parameter: higher = closer stations dominate more

# ── 1. Beach coordinates ──────────────────────────────────────────────────────
bc <- tibble(
  beach = c("Long Beach", "Twin Harbors", "Copalis", "Mocrocks", "Kalaloch"),
  blat  = c(46.361592,    46.855477,     47.133586,  47.238914,  47.606156),
  blon  = c(-124.069805, -124.118770,    -124.195585,-124.219583,-124.380790)
)
```

## 4a. Monthly IDW blending

```{r}
# ── Unique stations with valid coordinates from monthly data ───────────────
st <- wtmp_monthly %>%
  filter(!is.na(latitude), !is.na(longitude)) %>%
  distinct(station, latitude, longitude)

# Distance lookup: every beach to every station with valid coordinates
bsd <- bc %>%
  rowwise() %>%
  mutate(
    ds = list(
      st %>% mutate(d = hav(blat, blon, latitude, longitude))
    )
  ) %>%
  unnest(ds) %>%
  select(beach, station, d) %>%
  ungroup()

# ── IDW blended monthly temperature: mean, min, max ────────────────────────
aym <- wtmp_monthly %>% distinct(year, month)   # all year-month combos in the data

wi <- bc %>%
  select(beach) %>%
  cross_join(aym) %>%
  left_join(bsd, by = "beach", relationship = "many-to-many") %>%
  left_join(
    wtmp_monthly %>% select(station, year, month, wtmp_mean, wtmp_min, wtmp_max, wtmp_sd),
    by = c("station", "year", "month"), relationship = "many-to-many"
  ) %>%
  filter(!is.na(wtmp_mean), d <= max_dist) %>%
  mutate(w = 1 / d ^ idwp) %>%
  group_by(beach, year, month) %>%
  summarise(
    at       = weighted.mean(wtmp_mean, w = w),
    at_min   = weighted.mean(wtmp_min,  w = w),
    at_max   = weighted.mean(wtmp_max,  w = w),
    at_sd    = sqrt(weighted.mean(wtmp_sd^2, w = w)),
    ns       = n(),
    dom_stn  = station[which.max(w)],
    all_stns = paste(station, collapse = ", "),
    .groups  = "drop"
  )

# ── Completeness diagnostic ────────────────────────────────────────────────
cat("\n--- Monthly IDW completeness ---\n")
wi %>%
  group_by(beach) %>%
  summarise(
    nf = n(),
    ne = n_distinct(wtmp_monthly$year) * 12,
    pc = round(nf / ne, 3),
    an = round(mean(ns), 1),
    .groups = "drop"
  ) %>%
  print()

# ── Station attribution table (monthly) ───────────────────────────────────
# Which station names (from stations$Name) contribute to each beach?
stn_attr_monthly <- wi %>%
  select(beach, year, month, dom_stn, all_stns) %>%
  left_join(stations %>% select(station, Name), by = c("dom_stn" = "station")) %>%
  rename(dom_stn_name = Name)

cat("\n--- Dominant stations by beach (monthly) ---\n")
stn_attr_monthly %>%
  group_by(beach) %>%
  summarise(
    primary_station_id   = names(which.max(table(dom_stn))),
    primary_station_name = names(which.max(table(dom_stn_name))),
    all_contributing_ids = paste(unique(unlist(str_split(all_stns, ", "))), collapse = ", "),
    .groups = "drop"
  ) %>%
  print()

# ── Pivot to wide format for joining to clam data ─────────────────────────
ww <- wi %>%
  select(-dom_stn, -all_stns) %>%
  pivot_wider(
    names_from  = month,
    values_from = c(at, at_min, at_max, at_sd, ns),
    names_glue  = "{.value}_m{month}"
  )

# Safety check: must be exactly one row per beach × year before joining to dat
stopifnot(nrow(ww) == nrow(distinct(ww, beach, year)))

# ── Join to dat ────────────────────────────────────────────────────────────
dat_wtmp <- dat %>%
  mutate(sy = as.integer(str_extract(season, "^[0-9]{4}"))) %>%
  left_join(ww, by = c("beach", "sy" = "year")) %>%
  select(-sy)

# ── NULL diagnostic: check coverage ───────────────────────────────────────
cat("\n--- Monthly temperature coverage in clam data ---\n")
dat_wtmp %>%
  select(beach, season, matches("^at_m[0-9]+$")) %>%
  pivot_longer(matches("^at_m[0-9]+$"), names_to = "mo", values_to = "tmp") %>%
  group_by(beach) %>%
  summarise(
    n  = n(),
    na = sum(is.na(tmp)),
    p  = round(na / n, 3),
    .groups = "drop"
  ) %>%
  print()
```

