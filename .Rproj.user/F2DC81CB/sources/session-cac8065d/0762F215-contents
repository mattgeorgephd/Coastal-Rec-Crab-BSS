# ── Build modeling dataset ───────────────────────────────────────────────
# Reconstruct wide-format data with selected predictors at their optimal
# lags, plus lagged abundance for density-dependent models.

# Get monthly rec_lag (all lags already joined)
rl_monthly <- all_rec_lags[["monthly"]]

build_model_data <- function(beach_name, rtype, sel_preds, rec_lag_data, rec_data) {
  
  preds <- sel_preds %>%
    filter(beach == beach_name, recruit_type == rtype)
  
  if (nrow(preds) == 0) return(NULL)
  
  # Response variable
  resp_col <- ifelse(rtype == "Pre-recruits", "pre_recruits", "recruits")
  
  # Start with recruitment data for this beach
  md <- rec_data %>%
    filter(beach == beach_name) %>%
    select(sy, pre_recruits, recruits) %>%
    mutate(
      log_resp = log1p(.data[[resp_col]]),
      # Lagged abundance for density-dependent model
      log_resp_lag1 = dplyr::lag(log_resp, 1, order_by = sy)
    )
  
  # Join each selected predictor at its optimal lag
  for (i in 1:nrow(preds)) {
    tvar <- preds$temp_var[i]
    lg   <- preds$lag[i]
    pid  <- paste0("env", i)  # generic name: env1, env2
    
    pred_data <- rec_lag_data %>%
      filter(beach == beach_name, lag == lg) %>%
      select(sy, all_of(tvar)) %>%
      rename(!!pid := !!tvar)
    
    md <- md %>% left_join(pred_data, by = "sy")
  }
  
  # Add metadata
  attr(md, "beach")        <- beach_name
  attr(md, "recruit_type") <- rtype
  attr(md, "pred1_id")     <- preds$pred_id[1]
  attr(md, "pred2_id")     <- ifelse(nrow(preds) >= 2, preds$pred_id[2], NA)
  attr(md, "pred1_label")  <- paste0(preds$metric[1], " ", preds$window[1], " L", preds$lag[1])
  attr(md, "pred2_label")  <- ifelse(nrow(preds) >= 2,
                                      paste0(preds$metric[2], " ", preds$window[2], " L", preds$lag[2]),
                                      NA)
  
  return(md)
}

# ── AICc computation ─────────────────────────────────────────────────────
AICc <- function(model) {
  n <- nobs(model)
  k <- length(coef(model)) + 1  # +1 for residual variance
  aic <- AIC(model)
  aic + (2 * k * (k + 1)) / (n - k - 1)
}

# ── LOOCV function ───────────────────────────────────────────────────────
loocv <- function(formula, data) {
  n <- nrow(data)
  pred_vals <- numeric(n)
  for (i in 1:n) {
    fit_i    <- lm(formula, data = data[-i, ])
    pred_vals[i] <- predict(fit_i, newdata = data[i, , drop = FALSE])
  }
  obs <- data$log_resp
  ss_res <- sum((obs - pred_vals)^2, na.rm = TRUE)
  ss_tot <- sum((obs - mean(obs, na.rm = TRUE))^2, na.rm = TRUE)
  q2     <- 1 - ss_res / ss_tot
  rmse   <- sqrt(mean((obs - pred_vals)^2, na.rm = TRUE))
  list(q2 = q2, rmse = rmse, predicted = pred_vals)
}

# ── Rolling-origin cross-validation ──────────────────────────────────────
# Train on years 1..t, predict year t+1. Minimum training window = 10 years.
rolling_cv <- function(formula, data, min_train = 10) {
  n <- nrow(data)
  if (n <= min_train + 1) return(list(q2 = NA, rmse = NA, predicted = rep(NA, n)))
  
  pred_vals <- rep(NA_real_, n)
  for (t in min_train:(n - 1)) {
    fit_t <- tryCatch(
      lm(formula, data = data[1:t, ]),
      error = function(e) NULL
    )
    if (!is.null(fit_t)) {
      pred_vals[t + 1] <- predict(fit_t, newdata = data[t + 1, , drop = FALSE])
    }
  }
  
  valid_idx <- which(!is.na(pred_vals))
  if (length(valid_idx) < 3) return(list(q2 = NA, rmse = NA, predicted = pred_vals))
  
  obs    <- data$log_resp[valid_idx]
  prd    <- pred_vals[valid_idx]
  ss_res <- sum((obs - prd)^2)
  ss_tot <- sum((obs - mean(obs))^2)
  q2     <- 1 - ss_res / ss_tot
  rmse   <- sqrt(mean((obs - prd)^2))
  list(q2 = q2, rmse = rmse, predicted = pred_vals)
}

