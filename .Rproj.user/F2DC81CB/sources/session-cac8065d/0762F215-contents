# + best lag" for pre-whitening. Uses min temp, BEUTI, CUTI, and salinity.

fine_lag <- map_dfr(lag_range, function(lg) {
  map_dfr(1:12, function(mo) {
    
    # Temperature for this month from monthly IDW data
    temp_mo <- wi %>%
      filter(month == mo) %>%
      select(beach, year, at_min, at_max) %>%
