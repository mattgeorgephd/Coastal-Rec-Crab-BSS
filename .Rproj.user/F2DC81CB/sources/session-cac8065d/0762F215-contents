# ── Model comparison summary table ──────────────────────────────────────
# ═════════════════════════════════════════════════════════════════════════

# Combine all model comparison tables
all_model_stats <- map_dfr(model_results, function(res) {
  res$stats %>%
    mutate(beach = res$beach,
           recruit_type = res$recruit_type,
           pred1 = res$pred1_id,
           pred2 = res$pred2_id,
           .before = 1)
})

# ── Best model per beach × recruit type ──────────────────────────────────
best_models <- map_dfr(model_results, function(res) {
  best  <- res$stats %>% slice(1)
  bfit  <- res$fits[[best$model]]
  coefs <- coef(bfit)
  
  # Build equation string
  terms <- names(coefs)
  eq_parts <- sprintf("%.3f", coefs[1])  # intercept
  for (i in 2:length(terms)) {
    tname <- terms[i]
    # Resolve predictor label
    label <- case_when(
      tname == "env1" ~ res$pred1_id,
      tname == "env2" ~ res$pred2_id,
      tname == "log_resp_lag1" ~ "log(abund_{t-1})",
      TRUE ~ tname
    )
    sign <- ifelse(coefs[i] >= 0, " + ", " - ")
    eq_parts <- paste0(eq_parts, sign, sprintf("%.3f", abs(coefs[i])), " × ", label)
  }
  equation <- paste0("log(abund+1) = ", eq_parts)
  
  tibble(
    beach        = res$beach,
    recruit_type = res$recruit_type,
    best_model   = best$model,
    pred1        = res$pred1_label,
    pred2        = res$pred2_label,
    equation     = equation,
    n            = best$n,
    R2           = best$R2,
    adj_R2       = best$adj_R2,
    AICc         = best$AICc,
    delta_2nd    = res$stats$delta_AICc[min(2, nrow(res$stats))],
    Q2_LOOCV     = best$Q2_LOOCV,
    Q2_rolling   = best$Q2_rolling,
    RMSE_LOOCV   = best$RMSE_LOOCV
  )
}) %>%
  mutate(beach = factor(beach, levels = beach_order)) %>%
  arrange(beach, recruit_type)

cat("\n=== Best predictive model per beach × recruit type ===\n")
best_models %>%
  select(beach, recruit_type, best_model, R2, adj_R2, Q2_LOOCV, Q2_rolling) %>%
  print(n = Inf)

cat("\n=== Model equations ===\n")
best_models %>%
  select(beach, recruit_type, equation) %>%
  pwalk(function(beach, recruit_type, equation, ...) {
    cat(paste0(beach, " [", recruit_type, "]: ", equation, "\n"))
  })
