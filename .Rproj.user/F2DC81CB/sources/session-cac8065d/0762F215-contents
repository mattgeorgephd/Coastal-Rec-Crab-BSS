## Helper functions
```{r}
# ── Helper: Pearson r and p-value for a pair of vectors ─────────────────────
# Returns named vector c(r, p). Requires at least 5 complete pairs.
cor_p <- function(x, y) {
  d <- data.frame(x = x, y = y) %>% na.omit()
  if (nrow(d) > 4) {
    ct <- cor.test(d$x, d$y)
    c(r = unname(ct$estimate), p = unname(ct$p.value))
  } else {
    c(r = NA_real_, p = NA_real_)
  }
}

# ── Helper: tidy ACF/PACF computation ──────────────────────────────────────
# Returns a tibble with lag, acf value, and 95% CI bound.
tidy_acf <- function(x, lag_max = 10, type = "correlation") {
  x_clean <- x[!is.na(x)]
  if (length(x_clean) < 10) return(NULL)
  ac  <- acf(x_clean, lag.max = lag_max, type = type, plot = FALSE)
  ci  <- qnorm(0.975) / sqrt(length(x_clean))   # 95% Bartlett bound
  tibble(
    lag  = as.numeric(ac$lag),
    acf  = as.numeric(ac$acf),
    ci   = ci,
    type = type
  )
}

# ── Helper: tidy spectral analysis ─────────────────────────────────────────
# Returns tibble with freq, period, spectral density. Uses Daniell kernel smoothing.
tidy_spec <- function(x, series_name) {
  x_clean <- x[!is.na(x)]
  if (length(x_clean) < 12) return(NULL)
  x_interp <- approx(seq_along(x), x, xout = seq_along(x))$y
  sp <- spec.pgram(x_interp, spans = c(3, 3), taper = 0.1, plot = FALSE)
  tibble(
    freq    = sp$freq,
    period  = 1 / sp$freq,
    spec    = sp$spec,
    series  = series_name
  )
}

# ── Helper: Haversine distance (km) ────────────────────────────────────────
hav <- function(lat1, lon1, lat2, lon2) {
  R <- 6371
  p1 <- lat1 * pi / 180; p2 <- lat2 * pi / 180
  dp <- (lat2 - lat1) * pi / 180
  dl <- (lon2 - lon1) * pi / 180
  a  <- sin(dp/2)^2 + cos(p1) * cos(p2) * sin(dl/2)^2
  2 * R * asin(sqrt(a))
}
