# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 8: FULLY FACTORIAL PREDICTOR–RECRUITMENT LAG ANALYSIS
# ═══════════════════════════════════════════════════════════════════════════════

Investigates how seasonal predictors (min/max temperature, BEUTI, CUTI,
salinity) predict razor clam pre-recruit and recruit abundance at time lags
of 0, 1, and 2 years. Fully factorial across: timescale (monthly, half-
monthly, weekly) × metric (6) × recruit type (2) × seasonal window (5) ×
lag (3).

```{r}
# ── Predictor variable name vectors (6 metrics × 5 windows = 30 vars) ────
tv_min   <- c("t_spring_min",  "t_spawn_min",  "t_larval_min",  "t_settle_min",  "t_growth_min")
tv_max   <- c("t_spring_max",  "t_spawn_max",  "t_larval_max",  "t_settle_max",  "t_growth_max")
tv_beuti <- c("beuti_spring",  "beuti_spawn",  "beuti_larval",  "beuti_settle",  "beuti_growth")
tv_cuti  <- c("cuti_spring",   "cuti_spawn",   "cuti_larval",   "cuti_settle",   "cuti_growth")
tv_sal   <- c("sal_spring",    "sal_spawn",    "sal_larval",    "sal_settle",    "sal_growth")
tv_q     <- c("q_spring",      "q_spawn",      "q_larval",      "q_settle",      "q_growth")
tv_all   <- c(tv_min, tv_max, tv_beuti, tv_cuti, tv_sal, tv_q)

# Window and metric label lookups
window_labels <- c("Spring", "Spawn", "Larval", "Settle", "Growth")
tv_labels <- setNames(rep(window_labels, 6), tv_all)
metric_labels <- setNames(
  c(rep("Min", 5), rep("Max", 5), rep("BEUTI", 5), rep("CUTI", 5),
    rep("Salinity", 5), rep("Discharge", 5)),
  tv_all
)

# Ordered metric levels for consistent plotting
metric_levels <- c("Min", "Max", "CUTI", "BEUTI", "Salinity", "Discharge")

# ── Lag range ────────────────────────────────────────────────────────────
# Razor clams reach harvestable size in 3–5 years, so recruits detected in
# a survey reflect spawning/larval conditions 3–5 years prior. Lags 0–5
# capture the full life-history pathway:
#   Lag 0 = current-year mortality/growth
#   Lag 1 = juvenile survival (pre-recruits) / sub-adult growth (recruits)
#   Lag 2 = larval supply for pre-recruits / juvenile growth for recruits
#   Lag 3–5 = spawning/larval conditions for recruits (south→north gradient)
max_lag <- 5
lag_range <- 0:max_lag

# ── Recruitment base table ────────────────────────────────────────────────
rec <- dat_wtmp %>%
  select(beach, season, pre_recruits, recruits) %>%
  mutate(sy = as.integer(str_extract(season, "^[0-9]{4}")))

# ── Master function: run full lag correlation for one timescale ────────────
# Returns a tibble with columns: beach, lag, temp_var, window, metric,
#   r_pre, p_pre, r_rec, p_rec, sig_pre, sig_rec, timescale
run_lag_correlation <- function(ti_data, timescale_label) {
  
  # Join recruitment to predictor indices at lags 0 through max_lag
  rec_lag <- map_dfr(lag_range, function(lg) {
    rec %>%
      left_join(
        ti_data %>% mutate(sy = year + lg) %>% select(-year),
        by = c("beach", "sy")
      ) %>%
      mutate(lag = lg)
  })
  
  # Compute Pearson correlations for all combinations
  cor_result <- rec_lag %>%
    pivot_longer(all_of(tv_all), names_to = "temp_var", values_to = "temp_val") %>%
    group_by(beach, lag, temp_var) %>%
    summarise(
      n       = sum(!is.na(temp_val) & !is.na(pre_recruits)),
      r_pre   = cor_p(log1p(pre_recruits), temp_val)["r"],
      p_pre   = cor_p(log1p(pre_recruits), temp_val)["p"],
      r_rec   = cor_p(log1p(recruits),     temp_val)["r"],
      p_rec   = cor_p(log1p(recruits),     temp_val)["p"],
      .groups = "drop"
    ) %>%
    mutate(
      window    = tv_labels[temp_var],
      metric    = metric_labels[temp_var],
      sig_pre   = case_when(p_pre < 0.001 ~ "***", p_pre < 0.01 ~ "**",
                            p_pre < 0.05  ~ "*",   TRUE          ~ ""),
      sig_rec   = case_when(p_rec < 0.001 ~ "***", p_rec < 0.01 ~ "**",
                            p_rec < 0.05  ~ "*",   TRUE          ~ ""),
      timescale = timescale_label
    )
  
  return(list(cor_result = cor_result, rec_lag = rec_lag))
}

# ── Run the factorial analysis for available timescales ────────────────────
# Build a named list of seasonal index tables — only include timescales
# that successfully completed IDW blending and seasonal index computation.
ti_list <- list()
ti_list[["monthly"]]      <- ti_monthly
ti_list[["half_monthly"]]  <- ti_half_monthly
if (!is.null(ti_weekly)) ti_list[["weekly"]] <- ti_weekly

# Run lag correlations for each available timescale
results_list <- list()
for (ts_name in names(ti_list)) {
  res <- run_lag_correlation(ti_list[[ts_name]], ts_name)
  results_list[[ts_name]] <- res
}

# Combine all correlation results into one master table
cor_all <- bind_rows(lapply(results_list, function(x) x$cor_result))

# Build the rec_lag lookup for scatter plots (only available timescales)
all_rec_lags <- lapply(results_list, function(x) x$rec_lag)

# Report available timescales
available_timescales <- names(ti_list)

cat("\n--- Factorial analysis dimensions ---\n")
cat("Total correlation rows:", nrow(cor_all), "\n")
cat("Timescales completed:", paste(available_timescales, collapse = ", "), "\n")
cat("Metrics:",    paste(unique(cor_all$metric), collapse = ", "), "\n")
cat("Windows:",    paste(unique(cor_all$window), collapse = ", "), "\n")
```

